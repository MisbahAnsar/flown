# =============================================================================
# flowms Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------

# Secret used to encrypt session tokens and cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the app (required in production).
# Local dev: http://localhost:3000
# Production (Vercel): https://flowms.vercel.app
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# GitHub OAuth (via NextAuth)
# Create an OAuth App at: https://github.com/settings/developers
#
# LOCAL callback:  http://localhost:3000/api/auth/callback/github
# PRODUCTION callback: https://flowms.vercel.app/api/auth/callback/github
#
# GitHub allows ONE callback URL per OAuth App — use separate apps for local vs production.
# Scopes requested by the app: read:user, user:email, notifications
# -----------------------------------------------------------------------------

# GitHub OAuth App client ID
GITHUB_ID=

# GitHub OAuth App client secret
GITHUB_SECRET=

# Optional: personal access token for server-side GitHub API calls when the
# OAuth session token is unavailable (repo list, notifications fetch).
# Create at: https://github.com/settings/tokens — scopes: notifications, public_repo
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Stellar / Soroban (Testnet)
# -----------------------------------------------------------------------------

# Network passphrase for the target Stellar network.
# Testnet: Test SDF Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint URL.
# Testnet: https://soroban-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployed flowms audit-log Soroban contract ID.
STELLAR_CONTRACT_ID=CD3JPZA3CQUX6NZMXK4BPA5MQ4WLWA5NI32KWFPQXSAMGYIDWJILPAVC

# Server-side Stellar account secret key used to submit contract transactions.
# Use a dedicated testnet account; never commit the real value.
STELLAR_SECRET_KEY=

# -----------------------------------------------------------------------------
# Gemini (Thinker agent)
# Get an API key at: https://aistudio.google.com/apikey
# When unset, Thinker falls back to a deterministic template summary.
# -----------------------------------------------------------------------------

GEMINI_API_KEY=

# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Optional: Freighter wallet (client-side)
# Freighter reads the network from the user's wallet extension.
# No env vars required; included here for reference when wiring the UI.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Monitoring & Analytics (optional — recommended for production)
# -----------------------------------------------------------------------------

# Sentry DSN for client + server error monitoring.
# Create a project at https://sentry.io — only the public DSN is needed here.
# Never put auth tokens or secret keys in this variable.
# When unset, Sentry is disabled and errors are console-only.
NEXT_PUBLIC_SENTRY_DSN=

# Vercel Web Analytics custom events (wallet, instructions, audit trail).
# Enabled automatically in production on Vercel when @vercel/analytics is installed.
# Set to true in .env.local to test event tracking during local dev.
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=false
